# ==============================================================================
# SNode.C Identity Provider — Environment Configuration
# ==============================================================================
# Copy to .env before running docker compose up
# Never commit .env to git!

# ── Server ────────────────────────────────────────────────────────────────────
IDP_BASE_URL=https://auth.janeberwein.at
IDP_ISSUER=https://auth.janeberwein.at

# ── Redirect URIs ─────────────────────────────────────────────────────────────
# Comma-separated. LAN (RFC-1918) IPs are always allowed automatically.
IDP_ALLOWED_REDIRECT_URIS=https://app.janeberwein.at/auth/callback,http://localhost:8055/auth/callback

# ── TOTP Secret Encryption ────────────────────────────────────────────────────
# Optional: path to a 32-byte binary key file for AES-256-GCM encryption.
# If empty, TOTP secrets are stored as plaintext Base32 (development only).
# Generate: dd if=/dev/urandom bs=32 count=1 > /app/keys/totp.key
TOTP_KEY_PATH=

# ── Federated Login (optional) ────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=

OAUTH_META_CLIENT_ID=
OAUTH_META_CLIENT_SECRET=

# ── Email / Password Reset ────────────────────────────────────────────────────
# Command to send password reset emails. Receives email via stdin.
# Example: msmtp admin@janeberwein.at
# If empty, the reset link is shown in the browser (local mode).
SMTP_COMMAND=

# ── First-Run Admin Setup ─────────────────────────────────────────────────────
# Set this to a secret string before first run to enable /setup endpoint.
# It is consumed (cleared) after the first admin account is created.
# Generate: openssl rand -hex 32
SETUP_CLAIM_TOKEN=
